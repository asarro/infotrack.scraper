{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=infotrack;Username=postgres;Password=postgres"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "TargetSites": [
    {
      "Name": "solicitors.com",
      "TargetUrl": "https://www.solicitors.com/conveyancing",
      "Locations": [
        "London",
        "Birmingham",
        "Leeds",
        "Manchester",
        "Sheffield",
        "Bradford",
        "Liverpool",
        "Bristol"
      ]
    }
  ],
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "Infotrack.Scraper"
    }
  },
  "ScraperRetryPolicy": {
    "MaxRetryAttempts": 5,
    "InitialDelaySeconds": 1
  },
  "AllowedHosts": "*"
}
